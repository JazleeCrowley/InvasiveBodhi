#compare elevation and temperature. Good to link literature that generated simulated data.
rm(list = ls()) #keeps things blank, deletes object from work space. (remove the list of everything in the workspace)

##set parameters for simulated data
nobs <- 1000
xmin <- -20
xmax <- 20
slope <- -20
intcpt <- 5

##make x and y variables, faked the data here 
x <- runif(nobs, xmin, xmax)
ypred <- slope * x + intcpt

## temporary block to calibrate the slop and intercept
options(repr.plot.width = 5, repr.plot.height = 5)

par(
    pin = c(3, 3),
    bg = "white",
    fg = "black",
    col.axis = "black",
    col.lab = "black",
    col.main = "black"
    
)

## add noise
z <- rnorm(nobs, mean = 0, sd = 100)
yobs <- ypred + z

plot(x, yobs,
xlab = "Temperature",
ylab = "Elevation",
main = "Simulated Plot")

#verify that simulated data looks as expected
#example: shows that population size is >0

###Step 2: Fit model
fit <- glm(yobs ~ x)
summary(fit)

##Step 3: Plot for publication quality
plot(x, yobs,
xlab = "Temperature",
ylab = "Elevation",
main = "Simulated Plot")
abline(fit, col="turquoise", lwd = 2)
